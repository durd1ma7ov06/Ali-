OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_TEXT_MODEL=google/gemini-2.5-flash
GEMINI_TEXT_FALLBACK_MODELS=deepseek/deepseek-chat-v3-0324,google/gemini-2.0-flash-001

# ─────────────────────────────────────────────
# AI provider (provayder-agnostik)
# ─────────────────────────────────────────────
# Yangi nomlar: AI_API_KEY / AI_BASE_URL / AI_MODEL / AI_FALLBACK_MODELS.
# Eski OPENROUTER_API_KEY / GEMINI_TEXT_MODEL nomlari ham hurmat qilinadi.
# Faqat .env ni o'zgartirib istalgan OpenAI-mos provayderga o'ting:
#
#  OpenRouter (default):
#    AI_BASE_URL=https://openrouter.ai/api/v1
#    AI_MODEL=google/gemini-2.5-flash
#
#  Google AI Studio (OpenAI-mos endpoint):
#    AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#    AI_MODEL=gemini-2.0-flash
#
#  OpenAI:
#    AI_BASE_URL=https://api.openai.com/v1
#    AI_MODEL=gpt-4o-mini
#
#  Mahalliy Ollama:
#    AI_BASE_URL=http://localhost:11434/v1
#    AI_MODEL=llama3.2
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=google/gemini-2.5-flash
AI_FALLBACK_MODELS=deepseek/deepseek-chat-v3-0324:free
AI_PROVIDER=

EDGE_TTS_VOICE=uz-UZ-SardorNeural
EDGE_TTS_RATE=-5%
EDGE_TTS_PITCH=-15Hz
EDGE_TTS_VOLUME=+15%
STT_LANGUAGE=uz-UZ
LOCAL_TIMEZONE=Asia/Tashkent
GREETING_TEXT=Assalomu alaykum! Men Sohibqiron Amir Temurman. Sizga o'z tarixim va saltanatim haqida so'zlab beraman.
MICROPHONE_NAME=camera,webcam,uvc,fhd,1080p,a4ech,a4tech
MICROPHONE_DEVICE_INDEX=
CAMERA_ENABLED=true
CAMERA_INDEX=0
CAMERA_PREVIEW=true
CAMERA_FRAME_WIDTH=640
CAMERA_FRAME_HEIGHT=480
CAMERA_FPS=30
ESP32_SERIAL_ENABLED=true
ESP32_PORT=
ESP32_BAUDRATE=115200
FACE_SERVO_ENABLED=true
FACE_SERVO_MIN_ANGLE=20
FACE_SERVO_CENTER_ANGLE=90
FACE_SERVO_MAX_ANGLE=160
FACE_SERVO_DEAD_ZONE=0.08
FACE_SERVO_SMOOTHING=0.45
FACE_SERVO_MAX_STEP=7
FACE_SERVO_SEND_MIN_DELTA=1
FACE_SERVO_SEND_INTERVAL=0.04
FACE_SERVO_INVERT=false
FACE_DETECT_WIDTH=320
FACE_DETECT_SCALE_FACTOR=1.08
FACE_DETECT_MIN_NEIGHBORS=4
FACE_DETECT_MIN_SIZE=55
ARM_REST_RIGHT_SHOULDER_OFFSET=0
ARM_REST_RIGHT_ELBOW_OFFSET=0
ARM_REST_RIGHT_WRIST_OFFSET=90
ARM_REST_LEFT_SHOULDER_OFFSET=0
ARM_REST_LEFT_ELBOW_OFFSET=0
ARM_REST_LEFT_WRIST_OFFSET=45
STARTUP_GREETING_MOTION_ENABLED=true
GREETING_RIGHT_SHOULDER_OFFSET=44
GREETING_RIGHT_ELBOW_OFFSET=56
GREETING_RIGHT_WRIST_OFFSET=0
GREETING_HEAD_NOD=8
GREETING_HEAD_DELAY=0.14
GREETING_ARM_STEPS=8
GREETING_ARM_RETURN_STEPS=14
GREETING_ARM_STEP_DELAY=0.05
GREETING_RIGHT_ELBOW_START_DELAY=0.18
GREETING_RIGHT_WRIST_START_DELAY=0.0
GREETING_RIGHT_ELBOW_RETURN_DELAY=0.18
GREETING_RETURN_ELBOW_TO_SHOULDER_GAP=0.25
GREETING_RIGHT_SHOULDER_RETURN_DELAY=0.35
GREETING_RIGHT_WRIST_RETURN_DELAY=0.0
ARM_COMMAND_STEPS=10
ARM_COMMAND_STEP_DELAY=0.045
ARM_COMMAND_RAISE_SHOULDER_OFFSET=85
ARM_COMMAND_RAISE_ELBOW_OFFSET=15
ARM_COMMAND_RAISE_WRIST_OFFSET=0
ARM_COMMAND_BEND_ELBOW_OFFSET=80
ARM_COMMAND_WAVE_COUNT=3
ARM_COMMAND_WAVE_WRIST_OFFSET=35

# ─────────────────────────────────────────────
# Latency tuning
# ─────────────────────────────────────────────
# VAD: ambient noise calibration (seconds; 0 = skip)
VAD_AMBIENT_CALIBRATION_DURATION=1.0
# VAD: silence duration that ends an utterance (0.2–3.0 seconds)
VAD_PAUSE_THRESHOLD=0.6
# VAD: non-speech duration before VAD triggers (0.1–2.0 seconds)
VAD_NON_SPEAKING_DURATION=0.3
# VAD: maximum phrase capture duration in seconds (1–60)
VAD_PHRASE_TIME_LIMIT=8
# VAD: timeout waiting for speech to start in seconds (1–60)
VAD_LISTEN_TIMEOUT=5
# TTS: minimum buffered audio bytes before early playback starts (>= 512)
# 8192 gives smoother playback without noticeable extra latency
TTS_MIN_CHUNK_BYTES=8192
# AI: per-attempt timeout for API calls in seconds (0.1–300.0)
AI_REQUEST_TIMEOUT=6.0
# AI: max fallback models to try per turn. 1 is fastest.
AI_MAX_MODEL_ATTEMPTS=1
# Arm: max wait for previous arm job before proceeding (0.0–60.0 seconds)
ARM_COMMAND_TIMEOUT=5.0
# Turn: sleep after TTS playback before next listen (0.0–5.0 seconds; 0 = no delay)
TURN_COOLDOWN_SECONDS=0.0
# Logging: enable [TIMING] and [LATENCY CONFIG] output (true/false)
LATENCY_LOGGING_ENABLED=true
# Logging: verbosity level (summary = total turn time only; verbose = all stages)
LATENCY_LOG_LEVEL=summary

# ─────────────────────────────────────────────
# Round 2: Microphone, VAD energy, interrupt, TTS limits
# ─────────────────────────────────────────────
# Mic: force a specific device index (leave empty for auto-select)
MIC_DEVICE_INDEX=
# Mic: force by name substring (leave empty for auto-select)
MIC_DEVICE_NAME=
# VAD: enable dynamic energy threshold adjustment (true/false)
VAD_DYNAMIC_ENERGY_THRESHOLD=true
# VAD: static energy threshold (0–32767; used when dynamic=false or as starting point)
VAD_ENERGY_THRESHOLD=300
# Interrupt: enable stop-word listener during TTS playback (true/false)
INTERRUPT_LISTENER_ENABLED=true
# Interrupt: comma-separated stop words (multilingual)
INTERRUPT_STOP_WORDS=stop,cancel,enough,toxtat,to'xtat,yetarli,bas,bekor qil,остановись,стоп,хватит
# Interrupt: listen timeout per attempt in seconds (0.05–5.0)
INTERRUPT_LISTENER_TIMEOUT=0.25
# Interrupt: max phrase duration for stop-word capture in seconds (0.1–10.0)
INTERRUPT_LISTENER_PHRASE_LIMIT=2.0
# TTS: max characters to speak (0 = unlimited; truncates at sentence boundary)
TTS_MAX_TEXT_CHARS=0

# ─────────────────────────────────────────────
# Servo movement offsets (movement_commands.py)
# ─────────────────────────────────────────────
# Shoulder raise offset (positive = arm lifts up). Flip sign if servo is reversed.
ARM_RIGHT_SHOULDER_RAISE_OFFSET=55
ARM_LEFT_SHOULDER_RAISE_OFFSET=55
# Shoulder partial raise for chest pose
ARM_RIGHT_SHOULDER_CHEST_OFFSET=30
ARM_LEFT_SHOULDER_CHEST_OFFSET=30
# Elbow bend offset (positive = elbow bends forward/inward). Flip sign if reversed.
ARM_RIGHT_ELBOW_BEND_OFFSET=45
ARM_LEFT_ELBOW_BEND_OFFSET=45
# Wrist wave amplitude for silkit/salom
ARM_RIGHT_WRIST_WAVE_OFFSET=35
ARM_LEFT_WRIST_WAVE_OFFSET=35
# Wrist rotation offset for "bilak bur/aylantir"
ARM_RIGHT_WRIST_TURN_OFFSET=45
ARM_LEFT_WRIST_TURN_OFFSET=45
# Auto-return to neutral after each movement sequence (true/false)
ARM_AUTO_RETURN_TO_NEUTRAL=true

# ─────────────────────────────────────────────
# Movement parser & AI planner
# ─────────────────────────────────────────────
# Default per-step wait used by AI-planned sequences (milliseconds)
MOVEMENT_DEFAULT_STEP_WAIT_MS=500
# Maximum delay (seconds) accepted from "<N> soniyadan keyin" phrasing
MOVEMENT_DELAY_MAX_SECONDS=30
# Whether to fall back to AI structured-JSON planner when local parser fails
MOVEMENT_AI_PLANNER_ENABLED=true
# AI planner request timeout in seconds (kept low to stay responsive)
MOVEMENT_AI_PLANNER_TIMEOUT=8.0
# Spoken clarification when both local parser and AI planner produce no plan
MOVEMENT_CLARIFY_TEXT=Bu harakat buyrug'ini aniqroq ayting.

# ─────────────────────────────────────────────
# Face recognition (face_recognition_db.py)
# ─────────────────────────────────────────────
# Enable/disable face recognition entirely
FACE_RECOGNITION_ENABLED=true
# Path to face_data directory (relative to project root)
FACE_DATA_DIR=face_data
# SQLite embedding database path
FACE_DB_PATH=face_data/faces.sqlite
# InsightFace model pack (buffalo_l = best accuracy, ~280MB)
FACE_MODEL_NAME=buffalo_l
# Detector input size (640 = good speed/accuracy trade-off)
FACE_DET_SIZE=640
# Minimum detector confidence to accept a face (0.0–1.0)
FACE_MIN_DET_SCORE=0.65
# Minimum face size in pixels (shorter side of bbox)
FACE_MIN_FACE_PIXELS=50
# Cosine-similarity threshold for accepting a match (0.0–1.0)
# ArcFace genuine pairs are usually > 0.45; raise to 0.55 for tighter security.
FACE_MIN_SIMILARITY=0.45
# Minimum gap between top1 and top2 similarity (0.0–1.0)
# Raise to 0.12+ if the database has visually similar people.
FACE_MIN_MARGIN=0.08
# How often to run recognition on the camera feed (seconds)
FACE_RECOGNITION_INTERVAL=0.5
# Single-frame minimum confidence (0.0–1.0). Used when voting is disabled
# or as an extra gate.
FACE_RECOGNITION_MIN_CONFIDENCE=0.50
# Seconds before the same person can be greeted again
FACE_GREETING_COOLDOWN_SECONDS=60
# Greeting text template ({display_name}, {fio}, {person_id} are available)
FACE_GREETING_TEXT_TEMPLATE=Assalomu alaykum, {display_name}!
# Greet unknown (unrecognised) faces (default false)
FACE_GREETING_UNKNOWN_ENABLED=false
FACE_GREETING_UNKNOWN_TEXT=Assalomu alaykum!
# ── Stability / voting ──────────────────────────────────────────────────────
# Number of recent recognition frames to consider
FACE_RECOGNITION_VOTE_WINDOW=5
# Minimum frames the same person must win to confirm identity
FACE_RECOGNITION_VOTE_MIN_MATCHES=3
# Seconds without a face before resetting the current face session
FACE_SESSION_RESET_SECONDS=2.0
# ── Debug ───────────────────────────────────────────────────────────────────
# Print top1/top2 similarities every recognition frame (verbose)
FACE_RECOGNITION_DEBUG=false
# ── Legacy fallback knobs (only used if InsightFace cannot load) ────────────
FACE_LBPH_THRESHOLD=115
FACE_RECOGNITION_MAX_DISTANCE=0.65
FACE_RECOGNITION_MIN_MARGIN_LBPH=15
FACE_RECOGNITION_MIN_MARGIN_HIST=0.08

# ─────────────────────────────────────────────
# University knowledge RAG (Stage 3 — knowledge_qa.py)
# ─────────────────────────────────────────────
# Master switch for the local university knowledge engine.
UNIVERSITY_KNOWLEDGE_ENABLED=true
# Number of chunks to retrieve per question (1–10 typical).
UNIVERSITY_KNOWLEDGE_TOP_K=5
# Minimum relevance score for a retrieved chunk to be used. Below this the
# engine refuses to answer instead of guessing.
UNIVERSITY_KNOWLEDGE_MIN_SCORE=0.30
# Maximum characters of retrieved context passed to the AI.
UNIVERSITY_KNOWLEDGE_MAX_CONTEXT_CHARS=4500
# Exact Uzbek sentence used when the engine cannot ground an answer.
UNIVERSITY_KNOWLEDGE_NO_ANSWER_TEXT=Mening tarixim va faoliyatim haqida bunday ma'lumot topilmadi.
# Answer style hint ("short" recommended for spoken output).
UNIVERSITY_KNOWLEDGE_ANSWER_STYLE=short
# When true, refuse to answer if no source URL is attached to the chunks.
UNIVERSITY_KNOWLEDGE_REQUIRE_SOURCE=true
# When true, use the OpenRouter/Gemini AI to compose the grounded answer.
# When false (or no API key), extractive fallback is used.
UNIVERSITY_KNOWLEDGE_USE_AI=true
# Per-attempt timeout for the AI grounded answer call (seconds).
UNIVERSITY_KNOWLEDGE_AI_TIMEOUT=8.0
